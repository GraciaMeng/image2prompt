{
  "name": "image2prompt-extension",
  "version": "0.0.1",
  "description": "Chrome extension for turning webpage images into reusable AI image prompts with your own model.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "verify:dist": "node verify-dist.mjs",
    "check": "npm run typecheck && npm run test:run && npm run build && npm run verify:dist"
  },
  "dependencies": {
    "@fortaine/fetch-event-source": "^3.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.0.292",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "vitest": "^3.2.4"
  }
}
